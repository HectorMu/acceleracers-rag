# ── Provider selection ──────────────────────────────
# Supported: 'groq' | 'ollama'
# Chat defaults to 'groq'. Embedding defaults to 'ollama'
# (Groq doesn't support embedding models)
CHAT_PROVIDER=groq
CHAT_MODEL=llama-3.1-8b-instant

EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=nomic-embed-text

# ── Groq (used when CHAT_PROVIDER=groq) ──────────────
GROQ_API_KEY=gsk_your_key_here
# GROQ_BASE_URL=https://api.groq.com/openai/v1

# ── Ollama (used when EMBEDDING_PROVIDER=ollama) ─────
OLLAMA_URL=http://localhost:11434

# ── RAG ──────────────────────────────────────────────
CHUNK_SIZE=800
CHUNK_OVERLAP=100
TOP_K=4

# ── Server ───────────────────────────────────────────
PORT=3000

# ── Wiki ─────────────────────────────────────────────
WIKI_API=https://acceleracers.fandom.com/api.php
WIKI_BASE=https://acceleracers.fandom.com
WIKI_DELAY=500
