{
  "name": "acceleracers-rag",
  "version": "1.0.0",
  "description": "RAG-powered chatbot for the Hot Wheels Acceleracers universe",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "concurrently -n server,client -c cyan,green \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "tsx watch src/index.ts",
    "dev:client": "npm --prefix client run dev",
    "start": "node dist/index.js",
    "cli": "tsx src/index.ts --mode cli",
    "build": "tsc",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "rag",
    "acceleracers",
    "wiki",
    "ollama"
  ],
  "license": "MIT",
  "dependencies": {
    "@hono/node-server": "^1.14.0",
    "cheerio": "^1.2.0",
    "hono": "^4.7.0",
    "minisearch": "^7.2.0",
    "vectra": "^0.15.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "concurrently": "^10.0.3",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0"
  }
}
